{
  "version": 2,
  "name": "leon-diamond",
  "rewrites": [
    { "source": "/card", "destination": "/card.html" },
    { "source": "/scard", "destination": "/scard.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/earrings", "destination": "/earrings.html" },
    { "source": "/rings", "destination": "/rings.html" },
    { "source": "/bracelets", "destination": "/bracelets.html" },
    { "source": "/necklaces", "destination": "/necklaces.html" },
    { "source": "/bridal", "destination": "/bridal.html" }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
